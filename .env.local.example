# ═══════════════════════════════════════════
# Prompt Evolution Engine — Configuration
# ═══════════════════════════════════════════
# Copy this file to .env.local and fill in your values.

# AI Provider: "ollama" | "google-ai-studio" | "openrouter"
AI_PROVIDER=ollama

# Model ID depends on the selected provider.
# Examples: gemma4 (Ollama), gemini-2.5-flash (Google AI), google/gemma-4-26b-a4b-it:free (OpenRouter)
MODEL_ID=gemma4

# ─── Ollama (local) ───
OLLAMA_BASE_URL=http://localhost:11434

# Optional allowlist for remote Ollama hosts when ALLOW_REMOTE_ACCESS=true
OLLAMA_ALLOWED_HOSTS=

# ─── Google AI Studio (cloud, free) ───
# Get your key at: https://ai.google.dev/
GOOGLE_AI_API_KEY=

# ─── OpenRouter (cloud, free) ───
# Get your key at: https://openrouter.ai/
OPENROUTER_API_KEY=

# ─── Rate Limiting ───
# Delay in ms between API calls (0 for Ollama, 4200 for Google AI, 2000 for OpenRouter)
DELAY_BETWEEN_CALLS=0

# ─── Security ───
# Remote access is enabled by default unless you explicitly set this to false.
# If you expose the app publicly, add your own auth layer in front of it.
ALLOW_REMOTE_ACCESS=true
